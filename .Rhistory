library(foreign)
library(ggplot2)
library(tidyr)
library(Hmisc)
dat <- read.dta("MA_Poll_2014.dta", convert.factors = FALSE)
# use convert.factors=FALSE command when reading in data
# (this fixes an issue with how variables are labeled in .dta files)
table(dat$gender)
# Coded a new gender variable for nicer visualization downstream.
dat$gender2[dat$gender == 1] <- "Men"
dat$gender2[dat$gender ==2] <- "Women"
# Recoded those who skipped the question.
table(dat$Q2 == 997)
dat$Q2[ dat$Q2 == 997 ] <- NA
table(dat$Q2)
# The actual hypothesis test
t.test(Q2 ~ gender2, data=dat, conf.level = .95)
# Checked means because another student had a question.
mean(dat$Q2[dat$gender2 == "Men"], na.rm=TRUE)
mean(dat$Q2[dat$gender2 == "Women"], na.rm=TRUE)
t.test(dat$Q2[dat$gender2 == "Men"])$conf.int
t.test(dat$Q2[dat$gender2 == "Women"])$conf.int
theme_update(plot.title = element_text(hjust = 0.5))
p <- ggplot(dat, aes(x=gender2, y=Q2)) +
stat_summary(fun.data=mean_cl_normal, fun.args=list(conf.int=0.95))
p + ggtitle("Titley McTitleface") +
xlab("Gender") + ylab("Mean Likelihood to Vote (0-100)") + theme_bw() +theme(plot.title = element_text(hjust = 0.5)) +
theme(plot.title = element_text(face="bold", size=18)) +  theme(plot.title = element_text(hjust = 0.5))
table(dat$vb_vf_g2014)
dat$vb_vf_g2014[ dat$vb_vf_g2014 != "Y" ] <- "N"
table(dat$vb_vf_g2014)
# The actual hypothesis test
t.test(Q2 ~ gender2, data=dat, conf.level = .95)
prop.test(x=c(182, 209), n=c(359,441), correct=FALSE)
